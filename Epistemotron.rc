// Epistemotron.rc - Resource script for MFC application
#include "targetver.h"
#include "Resource.h"

#define APSTUDIO_READONLY_SYMBOLS
#include "afxres.h"
#undef APSTUDIO_READONLY_SYMBOLS

#ifdef APSTUDIO_INVOKED
#ifndef APSTUDIO_READONLY_SYMBOLS
#define _APS_NO_MFC
#define _APS_NEXT_RESOURCE_VALUE        327
#define _APS_NEXT_COMMAND_VALUE         32970
#define _APS_NEXT_CONTROL_VALUE         1000
#define _APS_NEXT_SYMED_VALUE           310
#endif
#endif

//------------------------------------------------------------------------------
// MAIN MENU (IDR_MAINFRAME is used as menu by LoadFrame)
//------------------------------------------------------------------------------
IDR_MAINFRAME MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&New\tCtrl+N", ID_FILE_NEW
        MENUITEM "&Open\tCtrl+O", ID_FILE_OPEN
        MENUITEM SEPARATOR
        MENUITEM "E&xit", ID_APP_EXIT
    END

    POPUP "&Simulation"
    BEGIN
        MENUITEM "&Start\tF5", ID_SIMULATION_START
        MENUITEM "&Pause\tF6", ID_SIMULATION_PAUSE
        MENUITEM "&Resume\tF7", ID_SIMULATION_RESUME
        MENUITEM "&Stop\tF8", ID_SIMULATION_STOP
        MENUITEM "&Reset", ID_SIMULATION_RESET
        MENUITEM SEPARATOR
        MENUITEM "Speed &Up", ID_SIMULATION_SPEED_UP
        MENUITEM "Speed &Down", ID_SIMULATION_SLOW_DOWN
        MENUITEM "&Step", ID_SIMULATION_STEP
        MENUITEM SEPARATOR
        MENUITEM "&Configuration...", ID_SIMULATION_CONFIG
    END

    POPUP "&Scenario"
    BEGIN
        MENUITEM "&Solar System", ID_SCENARIO_SOLAR_SYSTEM
        MENUITEM "&Binary Star", ID_SCENARIO_BINARY_STAR
        MENUITEM "&Three-Body", ID_SCENARIO_THREE_BODY
        MENUITEM "&Galaxy", ID_SCENARIO_GALAXY
        MENUITEM SEPARATOR
        MENUITEM "&Next Scenario", ID_SCENARIO_NEXT
    END

    POPUP "&View"
    BEGIN
        MENUITEM "&Toolbar", ID_VIEW_TOOLBAR
        MENUITEM "&Status Bar", ID_VIEW_STATUS_BAR
        MENUITEM SEPARATOR
        MENUITEM "&File View", ID_VIEW_FILEVIEW
        MENUITEM "&Class View", ID_VIEW_CLASSVIEW
        MENUITEM "&Output", ID_VIEW_OUTPUTWND
        MENUITEM "&Properties", ID_VIEW_PROPERTIESWND
        MENUITEM SEPARATOR
        MENUITEM "&Customize...", ID_VIEW_CUSTOMIZE
    END

    POPUP "&Window"
    BEGIN
        MENUITEM "&New Window", ID_WINDOW_NEW
        MENUITEM "&Arrange All", ID_WINDOW_ARRANGE
        MENUITEM "&Cascade", ID_WINDOW_CASCADE
        MENUITEM "&Tile Horizontal", ID_WINDOW_TILE_HORZ
        MENUITEM "&Tile Vertical", ID_WINDOW_TILE_VERT
        MENUITEM SEPARATOR
        MENUITEM "&Close All", ID_CLOSE_ALL
    END

    POPUP "&Help"
    BEGIN
        MENUITEM "&About Epistemotron...", ID_APP_ABOUT
    END
END

