    IDS_DEBUG_TAB           "Debug"
    IDS_FIND_TAB            "Find"
    IDS_EXPLORER            "Explorer"
    IDS_EDIT_MENU           "Edit Menu"
    IDS_FILE_VIEW           "File View"
    IDS_CLASS_VIEW          "Class View"
    IDS_OUTPUT_WND          "Output"
    IDS_PROPERTIES_WND      "Properties"
    IDS_SIMULATION_RUNNING  "Running"
